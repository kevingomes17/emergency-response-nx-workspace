{
  "name": "cloud-functions",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cloud-functions/src",
  "tags": ["scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/cloud-functions/tsconfig.json && tsc-alias -p apps/cloud-functions/tsconfig.json && cp apps/cloud-functions/package.json dist/apps/cloud-functions/package.json && cp apps/cloud-functions/.env dist/apps/cloud-functions/.env 2>/dev/null || true"
      },
      "outputs": ["{workspaceRoot}/dist/apps/cloud-functions"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "firebase emulators:start --only functions,firestore"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "firebase deploy --only functions"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
