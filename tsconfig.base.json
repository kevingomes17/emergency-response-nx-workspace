{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@emergency-response/control-room/data-access": [
        "libs/control-room/data-access/src/index.ts"
      ],
      "@emergency-response/control-room/feature-alerts": [
        "libs/control-room/feature-alerts/src/index.ts"
      ],
      "@emergency-response/control-room/feature-dashboard": [
        "libs/control-room/feature-dashboard/src/index.ts"
      ],
      "@emergency-response/control-room/feature-faq": [
        "libs/control-room/feature-faq/src/index.ts"
      ],
      "@emergency-response/control-room/feature-incident": [
        "libs/control-room/feature-incident/src/index.ts"
      ],
      "@emergency-response/control-room/feature-resources": [
        "libs/control-room/feature-resources/src/index.ts"
      ],
      "@emergency-response/control-room/ui-components": [
        "libs/control-room/ui-components/src/index.ts"
      ],
      "@emergency-response/shared/data-models": [
        "libs/shared/data-models/src/index.ts"
      ],
      "@emergency-response/shared/util-escalation": [
        "libs/shared/util-escalation/src/index.ts"
      ],
      "@emergency-response/shared/util-severity": [
        "libs/shared/util-severity/src/index.ts"
      ],
      "@emergency-response/shared/util-supabase": [
        "libs/shared/util-supabase/src/index.ts"
      ],
      "@emergency-response/control-room/feature-settings": [
        "libs/control-room/feature-settings/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
